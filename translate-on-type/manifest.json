{
  "manifest_version": 3,
  "name": "Neuro-Translator for inputs",
  "description": "One-click translation inside any input field",
  "version": "1.0",
  "permissions": ["activeTab"],
  "host_permissions": ["*://*/*"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["styles.css"],
    "run_at": "document_end"
  }],
  "icons": { "16": "icons/16.png",
             "32":  "icons/32.png",
             "48":  "icons/48.png",
             "128": "icons/128.png"}
}
